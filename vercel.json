{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/news/scrape",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/news/rss",
      "schedule": "0 7 * * 3"
    },
    {
      "path": "/api/care/cron/escalation",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/care/cron/checkin",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/care/cron/medications",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/care/cron/appointments",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/expire-invitations",
      "schedule": "0 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
