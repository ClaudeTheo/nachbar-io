{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/news/scrape",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/news/rss",
      "schedule": "0 7 * * 3"
    },
    {
      "path": "/api/care/cron/escalation",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/care/cron/checkin",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/care/cron/medications",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/care/cron/appointments",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/care/cron/shopping",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/care/cron/tasks",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/expire-invitations",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/onboarding",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/dormancy",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/care/cron/heartbeat-escalation",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/heartbeat-cleanup",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/subscription-check",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/analytics",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/welcome",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/event-reminders",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/recurring-events",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/waste-reminder",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/waste-sync",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/amtsblatt-sync",
      "schedule": "0 8 * * 6"
    },
    {
      "path": "/api/cron/hilfe-reminder",
      "schedule": "0 9 28 * *"
    },
    {
      "path": "/api/cron/quartier-info-sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/nina-sync",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/forensic-cleanup",
      "schedule": "0 4 * * *"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    }
  ]
}
