# ============================================================
# Nachbar.io — Umgebungsvariablen
# Kopieren zu .env.local und Werte eintragen
# ============================================================

# Supabase (EU Frankfurt)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# VAPID Keys für Web Push (generieren mit: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Anthropic Claude API (fuer News-Aggregation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Interne API-Secrets (generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
INTERNAL_API_SECRET=your-internal-secret
CRON_SECRET=your-cron-secret

# E-Mail (Resend — https://resend.com, kostenlos bis 100 E-Mails/Tag)
RESEND_API_KEY=re_your-resend-api-key
# Optional: Absenderadresse (erfordert verifizierte Domain bei Resend)
# EMAIL_FROM=Nachbar.io <noreply@nachbar.io>

# Site-URL (fuer Einladungslinks, Verifikations-E-Mails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
