# ============================================================
# nachbar-io — .env.local Template (Lokal-Modus)
# ============================================================
#
# Einfacher Weg: `node scripts/generate-local-env.mjs` erzeugt
# eine frische .env.local mit lokal-generierten Dev-Keys.
#
# Manueller Weg: diese Datei nach .env.local kopieren und Werte ergaenzen.
#
# Grundsatz: .env.local enthaelt NIEMALS Prod-Secrets. Fuer Cloud-Mode
# (echte Supabase-Prod) siehe .env.cloud.local.example und `npm run dev:cloud`.
# ============================================================

# --- Supabase LOKAL (CLI Demo-JWT-Keys, oeffentlich/unkritisch) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# --- Site / App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PILOT_MODE=true
PILOT_AUTO_VERIFY=true
AI_PROVIDER=mock
ADMIN_EMAIL=dev@localhost

# --- Encryption (LOKAL-ONLY — generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ---
CARE_ENCRYPTION_KEY=
CIVIC_ENCRYPTION_KEY=
RESIDENT_HASH_SECRET=

# --- Secrets (LOKAL-ONLY — beliebige Zufallsstrings, nicht Prod-Werte) ---
CRON_SECRET=
INTERNAL_API_SECRET=
E2E_TEST_SECRET=e2e-test-secret-dev
SECURITY_E2E_BYPASS=e2e-test-secret-dev

# --- Cloud-Services (lokal leer lassen — Features crashen ggf., das ist by design) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
TAVILY_API_KEY=
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_HILFE_PRICE_ID=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_MAPTILER_KEY=
