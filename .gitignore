# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Test output
playwright-report/
test-results/
.auth/

# Tool-generated
docs/superpowers/

# GitHub Actions Workflows erlauben
# .github/ — NICHT mehr ignoriert, wird fuer CI/CD benoetigt
.worktrees/

# Android signing
android/keystore.properties
android/key.properties
android/*.jks
android/*.keystore
*.keystore
.env*.local
.tmp-diag/

# Codex CLI Logs (lokale Background-Tasks)
.codex-*.log
.codex-*.err.log

# Playwright CLI Cache
.playwright-cli/

# Lokales Output-Verzeichnis
output/
