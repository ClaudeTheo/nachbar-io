# ============================================================
# nachbar-io — .env.cloud.local Template
# ============================================================
#
# Diese Datei zeigt die MINIMALE Struktur von .env.cloud.local.
# .env.cloud.local selbst ist gitignored und enthaelt die Prod-Werte.
#
# Laden passiert nur durch `npm run dev:cloud` (via scripts/dev-cloud.mjs).
#
# Regel: So wenig Secrets wie moeglich. Feature-spezifische Keys (Stripe,
# Resend, Twilio, AI-Provider, KV, VAPID, TURN, Sentry) hier NICHT per
# Default hinzufuegen. Wenn ein Feature im dev:cloud-Modus crasht weil sein
# Key fehlt, temporaer hier ergaenzen oder via Shell-export setzen.
# ============================================================

# --- Supabase Prod ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Encryption (Prod — noetig fuer Care/Civic/Resident-Felder-Entschluesselung) ---
CARE_ENCRYPTION_KEY=
CIVIC_ENCRYPTION_KEY=
RESIDENT_HASH_SECRET=

# --- Site / Flags ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PILOT_MODE=true
PILOT_AUTO_VERIFY=true
AI_PROVIDER=mock
ADMIN_EMAIL=you@example.com
