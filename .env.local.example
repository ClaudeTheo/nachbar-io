# ============================================================
# nachbar-io — Local Dev Template
# Copy to .env.local and fill in values (or use as-is for local Supabase)
# ============================================================
#
# Zwei Modi:
#   npm run dev        -> Liest .env.local (LOKAL — Default)
#   npm run dev:cloud  -> Liest .env.cloud.local (Cloud / Prod-Supabase)
#
# Fuer lokalen Modus: `npx supabase start` und diese Demo-Werte uebernehmen.
# Fuer Cloud-Modus: neuer `.env.cloud.local` mit echten Cloud-Keys anlegen.
# ============================================================

# --- Supabase (LOKAL — Demo-Defaults aus Supabase CLI) ---
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54421"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU"

# --- Site / App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
PILOT_MODE="true"
PILOT_AUTO_VERIFY="true"
AI_PROVIDER="mock"
ADMIN_EMAIL="you@example.com"

# --- Encryption / Secrets (Dev-Defaults — in echt erzeugen mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ---
CARE_ENCRYPTION_KEY="dev-care-encryption-key-32-hex-bytes-replace-me"
CIVIC_ENCRYPTION_KEY="dev-civic-encryption-key-32-hex-bytes-replace-me"
RESIDENT_HASH_SECRET="dev-resident-hash-secret-replace-me"
CRON_SECRET="dev-cron-secret-replace-me"
INTERNAL_API_SECRET="dev-internal-api-secret-replace-me"
E2E_TEST_SECRET="e2e-test-secret-dev"

# --- Cloud Services (brauchst du nur fuer spezifische Features) ---
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-proj-..."
GOOGLE_AI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash-lite"
RESEND_API_KEY="re_..."
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# --- Web Push (erzeugen mit: npx web-push generate-vapid-keys) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# --- Redis / KV (Upstash) ---
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
REDIS_URL=""

# --- Stripe (Test-Modus) ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PLUS_MONTHLY=""
STRIPE_PRICE_PLUS_YEARLY=""

# --- Monitoring / Maps ---
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_MAPTILER_KEY=""
